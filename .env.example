# MaydaIQ runtime mode.
# Keep true for reliable offline demos. Set false to call your Microsoft Foundry agent.
DEMO_MODE=false
DEFAULT_LANGUAGE=es

# REQUIRED FOR LIVE MICROSOFT FOUNDRY AGENT TESTING:

# From your Microsoft Foundry project overview.
# Expected format:
# https://<foundry-resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_FOUNDRY_PROJECT_ENDPOINT=

# IMPORTANT: agents with OBO-authenticated tools/documents require Entra auth.
# Use "entra" for your current Foundry agent. Use "api_key" only for agents/tools that support API key auth.
AZURE_FOUNDRY_AUTH_MODE=entra

# Optional: override only if Microsoft changes the audience required by your Foundry endpoint.
AZURE_FOUNDRY_TOKEN_SCOPE=https://ai.azure.com/.default

# Optional local-only fallback if Azure CLI is not available to the app process.
# Keep false for hosted/public demos; use a service principal there instead.
AZURE_FOUNDRY_ALLOW_INTERACTIVE_LOGIN=false

# Optional: only works for Foundry agents/tools that support API key auth. OBO tools do not.
AZURE_FOUNDRY_API_KEY=

# From your existing Foundry agent setup.
# If your documents are already attached to this agent, MaydaIQ can call the agent directly.
AZURE_FOUNDRY_AGENT_ID=

# From the playground sample. Example: 9
AZURE_FOUNDRY_AGENT_VERSION=

# OPTIONAL: only needed if you use the newer agent-reference flow by agent name.
AZURE_FOUNDRY_AGENT_NAME=

# Required by the Foundry Responses API. Use the model deployment shown in Models + Endpoints.
AZURE_FOUNDRY_MODEL_DEPLOYMENT=

# OPTIONAL ENTRA AUTHENTICATION:
# Leave these empty if you authenticate locally with `az login` / Azure CLI.
# Fill them for service-principal auth in hosted/public demos.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=


AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# OPTIONAL PUBLIC DEMO SETTINGS:
PUBLIC_EMERGENCY_CONTACT=local emergency services
PUBLIC_RESPONSE_ENTITIES=
# Format: Service|Phone|resource keywords|location keywords; another service|phone|...
# Example: Municipal traffic control|<number>|traffic control,road crew|cordoba,buen pastor
PUBLIC_RESPONSE_CONTACTS=

# OPTIONAL IMAGE ANALYSIS:
# If these are absent, MaydaIQ keeps using deterministic privacy-safe fallback.
AZURE_OPENAI_VISION_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# OPTIONAL / LEGACY:
FOUNDRY_IQ_KNOWLEDGE_BASE_ID=
FOUNDRY_IQ_CONNECTION_NAME=
